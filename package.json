{
  "name": "@ponchia/ui",
  "version": "0.3.6",
  "type": "module",
  "description": "Nothing-inspired, CSS-first UI framework — monochrome design tokens, one rationed accent, dot-matrix motifs, zero runtime dependencies, framework-agnostic.",
  "keywords": [
    "css",
    "ui",
    "ui-framework",
    "design-system",
    "design-tokens",
    "cascade-layers",
    "css-layers",
    "nothing",
    "monochrome",
    "framework-agnostic",
    "zero-dependencies",
    "dark-mode",
    "accessibility"
  ],
  "license": "MIT",
  "author": "Ponchia (https://github.com/Ponchia)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ponchia/bronto-ui.git"
  },
  "homepage": "https://github.com/Ponchia/bronto-ui#readme",
  "bugs": "https://github.com/Ponchia/bronto-ui/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "css",
    "dist",
    "fonts",
    "tokens",
    "classes",
    "behaviors",
    "glyphs",
    "shiki",
    "llms.txt",
    "docs/reference.md",
    "docs/theming.md",
    "docs/contrast.md",
    "docs/usage.md"
  ],
  "style": "./dist/bronto.css",
  "scripts": {
    "lint": "stylelint \"css/**/*.css\"",
    "lint:fix": "stylelint \"css/**/*.css\" --fix",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "tokens:build": "node scripts/gen-tokens-json.mjs",
    "dtcg:build": "node scripts/gen-dtcg.mjs",
    "resolved:build": "node scripts/gen-resolved.mjs",
    "dts:build": "node scripts/gen-dts.mjs",
    "glyphs:build": "node scripts/gen-glyphs.mjs",
    "skins:build": "node scripts/gen-skins.mjs",
    "reference:build": "node scripts/gen-reference.mjs",
    "contrast:build": "node scripts/gen-contrast.mjs",
    "vscode:build": "node scripts/gen-vscode-data.mjs",
    "dist:build": "node scripts/build-dist.mjs",
    "check:exports": "node scripts/check-exports.mjs",
    "check:tokens": "node scripts/check-tokens.mjs",
    "check:classes": "node scripts/check-classes.mjs",
    "check:dts": "node scripts/check-dts.mjs",
    "check:behaviors": "node scripts/check-behaviors.mjs",
    "check:glyphs": "node scripts/check-glyphs.mjs",
    "check:color-policy": "node scripts/check-color-policy.mjs",
    "check:skins": "node scripts/check-skins.mjs",
    "check:types": "tsc -p tsconfig.json",
    "check:dtcg": "node scripts/check-dtcg.mjs",
    "check:resolved": "node scripts/check-resolved.mjs",
    "check:shiki": "node scripts/check-shiki.mjs",
    "check:dist": "node scripts/check-dist.mjs",
    "check:pack": "node scripts/check-pack.mjs",
    "check:release": "node scripts/check-release.mjs",
    "check:reference": "node scripts/check-reference.mjs",
    "check:contrast": "node scripts/check-contrast.mjs",
    "check:vscode": "node scripts/check-vscode-data.mjs",
    "check": "npm run lint && npm run check:format && npm run check:exports && npm run check:tokens && npm run check:classes && npm run check:dts && npm run check:types && npm run check:dtcg && npm run check:resolved && npm run check:shiki && npm run check:dist && npm run check:pack && npm run check:release && npm run check:reference && npm run check:contrast && npm run check:vscode && npm run check:behaviors && npm run check:glyphs && npm run check:color-policy && npm run check:skins",
    "test": "node --test \"test/*.test.mjs\"",
    "prepack": "npm run tokens:build && npm run dtcg:build && npm run resolved:build && npm run dts:build && npm run reference:build && npm run contrast:build && npm run vscode:build && npm run skins:build && npm run dist:build && npm run glyphs:build",
    "prepublishOnly": "npm run check && npm test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-use-logical": "^2.1.3",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "style": "./dist/bronto.css",
      "default": "./dist/bronto.css"
    },
    "./dist/bronto.css": "./dist/bronto.css",
    "./css": "./css/core.css",
    "./css/core.css": "./css/core.css",
    "./css/tokens.css": "./dist/css/tokens.css",
    "./css/fonts.css": "./dist/css/fonts.css",
    "./css/base.css": "./dist/css/base.css",
    "./css/motion.css": "./dist/css/motion.css",
    "./css/dots.css": "./dist/css/dots.css",
    "./css/navigation.css": "./dist/css/navigation.css",
    "./css/site.css": "./dist/css/site.css",
    "./css/content.css": "./dist/css/content.css",
    "./css/primitives.css": "./dist/css/primitives.css",
    "./css/forms.css": "./dist/css/forms.css",
    "./css/feedback.css": "./dist/css/feedback.css",
    "./css/overlay.css": "./dist/css/overlay.css",
    "./css/disclosure.css": "./dist/css/disclosure.css",
    "./css/table.css": "./dist/css/table.css",
    "./css/app.css": "./dist/css/app.css",
    "./css/skins.css": "./dist/css/skins.css",
    "./css/unlayered/tokens.css": "./css/tokens.css",
    "./css/unlayered/fonts.css": "./css/fonts.css",
    "./css/unlayered/base.css": "./css/base.css",
    "./css/unlayered/motion.css": "./css/motion.css",
    "./css/unlayered/dots.css": "./css/dots.css",
    "./css/unlayered/navigation.css": "./css/navigation.css",
    "./css/unlayered/site.css": "./css/site.css",
    "./css/unlayered/content.css": "./css/content.css",
    "./css/unlayered/primitives.css": "./css/primitives.css",
    "./css/unlayered/forms.css": "./css/forms.css",
    "./css/unlayered/feedback.css": "./css/feedback.css",
    "./css/unlayered/overlay.css": "./css/overlay.css",
    "./css/unlayered/disclosure.css": "./css/disclosure.css",
    "./css/unlayered/table.css": "./css/table.css",
    "./css/unlayered/app.css": "./css/app.css",
    "./css/unlayered/skins.css": "./css/skins.css",
    "./tokens": {
      "types": "./tokens/index.d.ts",
      "default": "./tokens/index.js"
    },
    "./vscode.css-custom-data.json": "./classes/vscode.css-custom-data.json",
    "./tokens.json": "./tokens/index.json",
    "./tokens.dtcg.json": "./tokens/tokens.dtcg.json",
    "./tokens/resolved.json": "./tokens/resolved.json",
    "./shiki/nothing.json": "./shiki/nothing.json",
    "./llms.txt": "./llms.txt",
    "./docs/reference.md": "./docs/reference.md",
    "./docs/theming.md": "./docs/theming.md",
    "./docs/contrast.md": "./docs/contrast.md",
    "./docs/usage.md": "./docs/usage.md",
    "./classes": {
      "types": "./classes/index.d.ts",
      "default": "./classes/index.js"
    },
    "./behaviors": {
      "types": "./behaviors/index.d.ts",
      "default": "./behaviors/index.js"
    },
    "./glyphs": {
      "types": "./glyphs/glyphs.d.ts",
      "default": "./glyphs/glyphs.js"
    },
    "./skins": {
      "types": "./tokens/skins.d.ts",
      "default": "./tokens/skins.js"
    },
    "./fonts/*": "./fonts/*"
  }
}
