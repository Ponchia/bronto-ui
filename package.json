{
  "name": "@ponchia/ui",
  "version": "0.2.1",
  "type": "module",
  "description": "Shared Bronto UI framework — Nothing-inspired monochrome CSS theme, dot-matrix motifs, admin shell.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ponchia/bronto-ui.git"
  },
  "homepage": "https://github.com/Ponchia/bronto-ui#readme",
  "bugs": "https://github.com/Ponchia/bronto-ui/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "css",
    "fonts",
    "tokens",
    "classes",
    "behaviors"
  ],
  "scripts": {
    "lint": "stylelint \"css/**/*.css\"",
    "lint:fix": "stylelint \"css/**/*.css\" --fix",
    "tokens:build": "node scripts/gen-tokens-json.mjs",
    "check:exports": "node scripts/check-exports.mjs",
    "check:tokens": "node scripts/check-tokens.mjs",
    "check:classes": "node scripts/check-classes.mjs",
    "check:pack": "node scripts/check-pack.mjs",
    "check": "npm run lint && npm run check:exports && npm run check:tokens && npm run check:classes && npm run check:pack",
    "test": "node --test \"test/*.test.mjs\"",
    "prepack": "npm run tokens:build"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-use-logical": "^2.1.3"
  },
  "exports": {
    "./css": "./css/index.css",
    "./css/index.css": "./css/index.css",
    "./css/core.css": "./css/core.css",
    "./css/tokens.css": "./css/tokens.css",
    "./css/fonts.css": "./css/fonts.css",
    "./css/base.css": "./css/base.css",
    "./css/motion.css": "./css/motion.css",
    "./css/dots.css": "./css/dots.css",
    "./css/layout.css": "./css/layout.css",
    "./css/navigation.css": "./css/navigation.css",
    "./css/typography.css": "./css/typography.css",
    "./css/content.css": "./css/content.css",
    "./css/primitives.css": "./css/primitives.css",
    "./css/forms.css": "./css/forms.css",
    "./css/feedback.css": "./css/feedback.css",
    "./css/overlay.css": "./css/overlay.css",
    "./css/disclosure.css": "./css/disclosure.css",
    "./css/table.css": "./css/table.css",
    "./css/cards.css": "./css/cards.css",
    "./css/app.css": "./css/app.css",
    "./css/responsive.css": "./css/responsive.css",
    "./tokens": {
      "types": "./tokens/index.d.ts",
      "default": "./tokens/index.js"
    },
    "./tokens.json": "./tokens/index.json",
    "./classes": {
      "types": "./classes/index.d.ts",
      "default": "./classes/index.js"
    },
    "./behaviors": {
      "types": "./behaviors/index.d.ts",
      "default": "./behaviors/index.js"
    },
    "./fonts/*": "./fonts/*"
  }
}
